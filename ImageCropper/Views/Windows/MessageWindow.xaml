<Window
    x:Class="ImageCropper.Views.Windows.MessageWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ImageCropper.Views.Windows"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="MessageWindow"
    Width="300"
    Height="120"
    WindowStyle="None"
    mc:Ignorable="d">
    <Grid Margin="10">
        <StackPanel>
            <TextBlock
                x:Name="TitleText"
                FontSize="16"
                FontWeight="Bold"
                Text="フォルダを再帰的に検索しています" />
            <TextBlock
                x:Name="MessageText"
                Grid.Row="2"
                Margin="0,5,0,0"
                Text="この処理には長い時間がかかる場合があります。" />
            <Button
                Width="100"
                Margin="0,10,0,0"
                HorizontalAlignment="Center"
                Click="Cancel_Button_Click"
                Content="キャンセル" />
        </StackPanel>
    </Grid>
</Window>
