<Window
    x:Class="ImageCropper.Views.Windows.ProgressWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="画像処理中"
    Width="400"
    Height="200"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterOwner"
    WindowStyle="None"
    mc:Ignorable="d">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock
            FontSize="16"
            FontWeight="Bold"
            Text="画像を処理しています..." />
        <ProgressBar
            Grid.Row="1"
            Height="25"
            Margin="0,10,0,0"
            Maximum="100"
            Minimum="0"
            Value="{Binding Progress}" />
        <TextBlock
            Grid.Row="2"
            Margin="0,5,0,0"
            Text="{Binding Current}" />
        <StackPanel Grid.Row="3" Margin="0,5,0,0">
            <TextBlock FontWeight="Bold" Text="{Binding FileName}" />
            <TextBlock Text="{Binding Message}" TextWrapping="Wrap" />
        </StackPanel>
        <Button
            Grid.Row="4"
            Width="100"
            Margin="0,10,0,0"
            HorizontalAlignment="Center"
            Command="{Binding CancelCommand}"
            Content="キャンセル"
            IsEnabled="{Binding IsCancellationRequested, Converter={StaticResource InverseBooleanConverter}}"
            Visibility="{Binding IsCancelButtonVisible, Converter={StaticResource BooleanToVisibilityConverter}}" />
    </Grid>
</Window>
