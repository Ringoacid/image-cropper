<Window
    x:Class="ImageCropper.Views.Windows.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Interactivity="clr-namespace:Reactive.Bindings.Interactivity;assembly=ReactiveProperty.WPF"
    xmlns:behaviors="clr-namespace:ImageCropper.Behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:ImageCropper.Views.Windows"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:uc="clr-namespace:ImageCropper.Views.UserControls"
    Title="ImageCropper"
    Width="800"
    Height="450"
    d:DataContext="{d:DesignInstance Type=local:MainWindow}"
    Closed="Window_Closed"
    Loaded="Window_Loaded"
    mc:Ignorable="d">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding ViewModel.LoadedCommand}" />
        </i:EventTrigger>
        <i:EventTrigger EventName="Closed">
            <i:InvokeCommandAction Command="{Binding ViewModel.ClosedCommand}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Window.InputBindings>
        <KeyBinding Key="Z" Modifiers="Ctrl" Command="{Binding ViewModel.UndoCommand}" />
        <KeyBinding Key="Y" Modifiers="Ctrl" Command="{Binding ViewModel.RedoCommand}" />
        <KeyBinding Key="Z" Modifiers="Ctrl+Shift" Command="{Binding ViewModel.RedoCommand}" />
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Menu>
            <MenuItem Header="ファイル">
                <MenuItem Command="{Binding ViewModel.OpenImageClickCommand}" Header="画像を開く" />
                <MenuItem Command="{Binding ViewModel.OpenFolderClickCommand}" Header="フォルダを開く" />
                <MenuItem Command="{Binding ViewModel.OpenFolderRecursivelyClickCommand}" Header="再帰的にフォルダを開く" />
                <Separator />
                <MenuItem Command="{Binding ViewModel.SetOutputFolderClickCommand}" Header="出力先フォルダを選択" />
                <MenuItem Command="{Binding ViewModel.CropImageCommand}" Header="画像切り取り" />
            </MenuItem>
            <MenuItem Header="編集">
                <MenuItem Command="{Binding ViewModel.UndoCommand}" Header="元に戻す" InputGestureText="Ctrl+Z" />
                <MenuItem Command="{Binding ViewModel.RedoCommand}" Header="やり直す" InputGestureText="Ctrl+Y" />
            </MenuItem>
            <MenuItem Header="設定">
                <MenuItem Command="{Binding ViewModel.OpenSettingsWindowCommand}" Header="設定ウィンドウを開く" />
                <Separator />
                <MenuItem Command="{Binding ViewModel.ResetSettingsCommand}" Header="設定をリセット" />
            </MenuItem>
            <MenuItem Header="ヘルプ">
                <MenuItem Command="{Binding ViewModel.OpenGitHubRepositoryCommand}" Header="GitHubのリポジトリを開く" />
                <MenuItem Command="{Binding ViewModel.CheckForUpdatesCommand}" Header="更新を確認" />
                <MenuItem Command="{Binding ViewModel.ShowAboutCommand}" Header="ImageCropperについて" />
            </MenuItem>
        </Menu>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="4" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock
                    Margin="5"
                    HorizontalAlignment="Left"
                    FontSize="16"
                    FontWeight="Bold"
                    Text="入力画像" />


                <ListView
                    Grid.Row="1"
                    behaviors:MultiSelectionBehavior.SelectedItems="{Binding ViewModel.SelectedImages}"
                    AllowDrop="True"
                    DisplayMemberPath="DisplayName"
                    ItemsSource="{Binding ViewModel.ImagePaths}"
                    SelectedItem="{Binding ViewModel.SelectedImage}"
                    Tag="{Binding RelativeSource={RelativeSource AncestorType=Window}}">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Tag" Value="{Binding RelativeSource={RelativeSource AncestorType=ListView}, Path=Tag}" />
                            <Setter Property="ContextMenu">
                                <Setter.Value>
                                    <ContextMenu>
                                        <MenuItem
                                            Command="{Binding PlacementTarget.Tag.ViewModel.OpenImageFolderInExplorerCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                            CommandParameter="{Binding}"
                                            Header="フォルダを開く" />
                                    </ContextMenu>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>

                    <i:Interaction.Triggers>
                        <i:EventTrigger EventName="Drop">
                            <Interactivity:EventToReactiveCommand Command="{Binding ViewModel.DropCommand}" />
                        </i:EventTrigger>

                        <i:EventTrigger EventName="KeyDown">
                            <Interactivity:EventToReactiveCommand Command="{Binding ViewModel.ListKeyDownCommand}" />
                        </i:EventTrigger>
                    </i:Interaction.Triggers>
                </ListView>

                <WrapPanel Grid.Row="2" Margin="5">
                    <TextBlock Text="画像の数：" />
                    <TextBlock Text="{Binding ViewModel.ImagePaths.Count}" />
                </WrapPanel>
            </Grid>

            <GridSplitter
                Grid.Column="1"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Background="Gray"
                ShowsPreview="True" />

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Background="Black">
                        <StackPanel.Resources>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="TextWrapping" Value="Wrap" />
                                <Setter Property="Margin" Value="5,0,0,0" />
                            </Style>
                        </StackPanel.Resources>

                        <TextBlock
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Text="{Binding ViewModel.SelectedImage.Item}"
                            TextWrapping="NoWrap" />
                        <TextBlock
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Text="{Binding ViewModel.SelectedImageInformation}"
                            TextWrapping="NoWrap" />
                    </StackPanel>

                    <uc:EditableImage
                        x:Name="CropRangeEditableImage"
                        Grid.Row="1"
                        CreatedRectangle="{Binding ViewModel.CreatedRectangle, Mode=TwoWay}"
                        CropRange="{Binding ViewModel.CropRangePixelCoordinates, Mode=TwoWay}"
                        ImageInformation="{Binding ViewModel.SelectedImageInformation}"
                        ImageSource="{Binding ViewModel.SelectedImage.Item}"
                        IsManualSettingsWindowOpen="{Binding ViewModel.IsManualSettingsWindowOpen, Mode=TwoWay}"
                        UISettings="{Binding ViewModel.UISettings}" />

                    <!--  ViewModel.IsManualSettingsWindowOpenがtrueの時だけ表示  -->
                    <TextBlock
                        Grid.Row="2"
                        Background="#ffffaa"
                        FontSize="16"
                        Text="手動設定ウィンドウが開いています。矩形の新規作成や削除が制限されています。"
                        Visibility="{Binding ViewModel.IsManualSettingsWindowOpen, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </Grid>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <WrapPanel VerticalAlignment="Center">
                            <Button
                                Margin="5"
                                Padding="5"
                                Command="{Binding ViewModel.SetOutputFolderClickCommand}"
                                Content="出力先フォルダを選択" />
                            <TextBlock Margin="5" Text="出力先フォルダ:" />
                            <TextBlock
                                Margin="5"
                                Cursor="Hand"
                                Text="{Binding ViewModel.OutputSettings.FolderPath}">
                                <i:Interaction.Triggers>
                                    <i:EventTrigger EventName="MouseLeftButtonDown">
                                        <i:InvokeCommandAction Command="{Binding ViewModel.OutputFolderClickCommand}" />
                                    </i:EventTrigger>
                                </i:Interaction.Triggers>
                            </TextBlock>
                        </WrapPanel>

                        <WrapPanel Grid.Row="1" VerticalAlignment="Center">
                            <StackPanel>
                                <TextBlock Margin="5" Text="出力拡張子：" />
                                <ComboBox
                                    Width="100"
                                    Margin="5"
                                    ItemsSource="{Binding ViewModel.SupportedOutputExtensions}"
                                    SelectedValue="{Binding ViewModel.OutputSettings.Extension}" />
                            </StackPanel>

                            <StackPanel Margin="10,0,0,0">
                                <TextBlock Margin="5" Text="マルチスレッド処理" />
                                <uc:ToggleSwitch HorizontalAlignment="Center" IsChecked="{Binding ViewModel.OutputSettings.IsUseMultiThreading}" />
                            </StackPanel>

                            <StackPanel Margin="10,0,0,0">
                                <TextBlock Margin="5" Text="切り取り範囲が画像外でも処理" />
                                <uc:ToggleSwitch HorizontalAlignment="Center" IsChecked="{Binding ViewModel.OutputSettings.IsCropOutsideImageAllowed}" />
                            </StackPanel>
                        </WrapPanel>

                        <WrapPanel Grid.Row="2" VerticalAlignment="Center">
                            <TextBlock Margin="5" Text="テンプレート：" />
                            <ComboBox
                                Width="160"
                                Margin="5"
                                DisplayMemberPath="Name"
                                ItemsSource="{Binding ViewModel.Presets}"
                                SelectedItem="{Binding ViewModel.SelectedPreset}" />
                            <Button
                                Margin="5"
                                Padding="5"
                                Command="{Binding ViewModel.ApplyPresetCommand}"
                                Content="適用" />
                        </WrapPanel>
                    </Grid>

                    <Grid Grid.Column="1">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ViewModel.IsManualSettingsWindowOpen}" Value="True">
                                        <Setter Property="ToolTip" Value="手動設定ウィンドウを閉じてください" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <Button
                            Margin="5"
                            Padding="5"
                            Background="Aqua"
                            Command="{Binding ViewModel.CropImageCommand}"
                            Content="切り取り実行" />
                    </Grid>
                </Grid>

            </Grid>
        </Grid>
    </Grid>
</Window>
