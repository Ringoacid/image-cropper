<Window
    x:Class="ImageCropper.Views.Windows.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:ImageCropper.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:ImageCropper.Views.Windows"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:uc="clr-namespace:ImageCropper.Views.UserControls"
    xmlns:vm="clr-namespace:ImageCropper.ViewModels.Windows"
    Title="設定"
    Width="500"
    Height="400"
    d:DataContext="{d:DesignInstance Type=local:SettingsWindow}"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">

    <Window.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:EnumToDisplayStringConverter x:Key="EnumToDisplayStringConverter" />

        <Style x:Key="ChangedHighlightBorder" TargetType="Border">
            <Style.Setters>
                <Setter Property="Background" Value="#f5f5f5" />
            </Style.Setters>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="True">
                    <Setter Property="Background" Value="#E0F7FF" />
                    <Setter Property="BorderBrush" Value="#00BFFF" />
                    <Setter Property="BorderThickness" Value="2" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="False">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="BorderBrush" Value="Transparent" />
                    <Setter Property="BorderThickness" Value="2" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SettingLabel" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="5" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" Margin="10">
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock VerticalAlignment="Center" Text="出力" />
                        <Ellipse
                            Width="8"
                            Height="8"
                            Margin="5,0,0,0"
                            Fill="#00BFFF"
                            Visibility="{Binding ViewModel.IsAnyOutputSettingChanged, Converter={StaticResource BoolToVisibilityConverter}}" />
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer Padding="10" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border
                            Margin="0,5"
                            Padding="5"
                            CornerRadius="5"
                            Style="{StaticResource ChangedHighlightBorder}"
                            Tag="{Binding ViewModel.IsOutputExtensionChanged}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Grid.Column="0"
                                    Style="{StaticResource SettingLabel}"
                                    Text="出力拡張子：" />
                                <ComboBox
                                    Grid.Column="1"
                                    Width="120"
                                    HorizontalAlignment="Right"
                                    ItemsSource="{Binding ViewModel.SupportedOutputExtensions}"
                                    SelectedValue="{Binding ViewModel.EditingOutputSettings.Extension}" />
                            </Grid>
                        </Border>

                        <Border
                            Margin="0,5"
                            Padding="5"
                            CornerRadius="5"
                            Style="{StaticResource ChangedHighlightBorder}"
                            Tag="{Binding ViewModel.IsOutputFolderPathChanged}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock
                                    Grid.Row="0"
                                    Style="{StaticResource SettingLabel}"
                                    Text="出力先フォルダパス：" />
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        Grid.Column="0"
                                        Margin="5"
                                        Padding="5"
                                        VerticalAlignment="Center"
                                        Cursor="Hand"
                                        Text="{Binding ViewModel.EditingOutputSettings.FolderPath}"
                                        TextWrapping="Wrap">
                                        <i:Interaction.Triggers>
                                            <i:EventTrigger EventName="MouseLeftButtonDown">
                                                <i:InvokeCommandAction Command="{Binding ViewModel.OutputFolderClickCommand}" />
                                            </i:EventTrigger>
                                        </i:Interaction.Triggers>
                                    </TextBlock>
                                    <Button
                                        Grid.Column="1"
                                        Margin="5"
                                        Padding="10,5"
                                        Command="{Binding ViewModel.SelectOutputFolderCommand}"
                                        Content="参照..." />
                                </Grid>
                            </Grid>
                        </Border>

                        <Border
                            Margin="0,5"
                            Padding="5"
                            CornerRadius="5"
                            Style="{StaticResource ChangedHighlightBorder}"
                            Tag="{Binding ViewModel.IsUseMultiThreadingChanged}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Grid.Column="0"
                                    Style="{StaticResource SettingLabel}"
                                    Text="マルチスレッド処理：" />
                                <uc:ToggleSwitch
                                    Grid.Column="1"
                                    HorizontalAlignment="Right"
                                    IsChecked="{Binding ViewModel.EditingOutputSettings.IsUseMultiThreading}" />
                            </Grid>
                        </Border>

                        <Border
                            Margin="0,5"
                            Padding="5"
                            CornerRadius="5"
                            Style="{StaticResource ChangedHighlightBorder}"
                            Tag="{Binding ViewModel.IsCropOutsideImageAllowedChanged}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Grid.Column="0"
                                    Style="{StaticResource SettingLabel}"
                                    Text="切り取り範囲が画像外でも処理するか：" />
                                <uc:ToggleSwitch
                                    Grid.Column="1"
                                    HorizontalAlignment="Right"
                                    IsChecked="{Binding ViewModel.EditingOutputSettings.IsCropOutsideImageAllowed}" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock VerticalAlignment="Center" Text="UI" />
                        <Ellipse
                            Width="8"
                            Height="8"
                            Margin="5,0,0,0"
                            Fill="#00BFFF"
                            Visibility="{Binding ViewModel.IsAnyUISettingChanged, Converter={StaticResource BoolToVisibilityConverter}}" />
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer Padding="10" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border
                            Margin="0,5"
                            Padding="5"
                            CornerRadius="5"
                            Style="{StaticResource ChangedHighlightBorder}"
                            Tag="{Binding ViewModel.IsRangeDisplayModeChanged}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock
                                    Grid.Row="0"
                                    Style="{StaticResource SettingLabel}"
                                    Text="ドラッグ中の範囲表示：" />
                                <ComboBox
                                    Grid.Row="1"
                                    Margin="5"
                                    ItemsSource="{Binding Source={x:Static vm:SettingsWindowViewModel.RangeDisplayModes}}"
                                    SelectedItem="{Binding ViewModel.EditingUISettings.RangeDisplayMode}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Converter={StaticResource EnumToDisplayStringConverter}}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="テンプレート">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border
                        Padding="5"
                        BorderBrush="#ccc"
                        BorderThickness="1"
                        CornerRadius="3">
                        <ListBox
                            BorderThickness="0"
                            DisplayMemberPath="Name"
                            ItemsSource="{Binding ViewModel.Presets}"
                            SelectedItem="{Binding ViewModel.SelectedPreset}" />
                    </Border>

                    <StackPanel
                        Grid.Row="1"
                        Margin="0,8,0,0"
                        Orientation="Horizontal">
                        <Button
                            Padding="10,5"
                            Command="{Binding ViewModel.SaveCurrentAsPresetCommand}"
                            Content="現在の設定で保存" />
                        <Button
                            Margin="8,0,0,0"
                            Padding="10,5"
                            Command="{Binding ViewModel.DeletePresetCommand}"
                            Content="削除" />
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="エクスポート/インポート">
                <StackPanel Margin="10" VerticalAlignment="Top">
                    <TextBlock
                        Margin="5"
                        FontSize="14"
                        FontWeight="Bold"
                        Text="設定のエクスポート/インポート" />

                    <TextBlock
                        Margin="5,10,5,20"
                        Text="設定をJSONファイルにエクスポートしたり、以前エクスポートしたファイルから設定をインポートできます。"
                        TextWrapping="Wrap" />

                    <StackPanel Margin="5" Orientation="Horizontal">
                        <Button
                            Padding="20,10"
                            Command="{Binding ViewModel.ExportSettingsCommand}"
                            Content="設定をエクスポート" />
                        <Button
                            Margin="10,0,0,0"
                            Padding="20,10"
                            Command="{Binding ViewModel.ImportSettingsCommand}"
                            Content="設定をインポート" />
                    </StackPanel>
                </StackPanel>
            </TabItem>
        </TabControl>

        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button
                Grid.Column="1"
                MinWidth="80"
                Margin="5"
                Padding="15,8"
                Command="{Binding ViewModel.OkCommand}"
                Content="OK"
                IsDefault="True" />
            <Button
                Grid.Column="2"
                MinWidth="80"
                Margin="5"
                Padding="15,8"
                Command="{Binding ViewModel.CancelCommand}"
                Content="キャンセル"
                IsCancel="True" />
        </Grid>
    </Grid>
</Window>
