<UserControl
    x:Class="ImageCropper.Views.UserControls.EditableImage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ImageCropper.Views.UserControls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    Focusable="True"
    mc:Ignorable="d">


    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  ScrollViewerで画像全体をスクロールできるようにする  -->
        <Grid x:Name="ImagePolygonGrid">
            <ScrollViewer
                Name="scrollViewer"
                Grid.Column="2"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                HorizontalScrollBarVisibility="Auto"
                VerticalScrollBarVisibility="Auto">
                <!--  拡大縮小のためにGridでラップ  -->
                <Grid Background="Transparent" MouseLeftButtonUp="Grid_MouseLeftButtonUp">
                    <!--  画像表示用  -->
                    <Image
                        x:Name="image"
                        MouseLeftButtonDown="OnImageMouseLeftButtonDown"
                        MouseMove="Image_MouseMove"
                        MouseRightButtonDown="Image_MouseRightButtonDown"
                        MouseRightButtonUp="Image_MouseRightButtonUp"
                        MouseWheel="Image_MouseWheel"
                        Stretch="None">
                        <Image.LayoutTransform>
                            <!--  拡大縮小用のTransformを指定  -->
                            <ScaleTransform x:Name="scaleTransform" ScaleX="1" ScaleY="1" />
                        </Image.LayoutTransform>
                    </Image>
                    <!--  ポリゴン描画用Canvas  -->
                    <Canvas Name="overlayCanvas" IsHitTestVisible="True">
                        <Canvas.LayoutTransform>
                            <ScaleTransform ScaleX="{Binding ScaleX, ElementName=scaleTransform}" ScaleY="{Binding ScaleY, ElementName=scaleTransform}" />
                        </Canvas.LayoutTransform>
                    </Canvas>

                    <!--  UIオーバーレイ用Canvas（ズームの影響を受けない）  -->
                    <Canvas Name="uiOverlayCanvas" IsHitTestVisible="False">
                        <!--  切り取り範囲表示用  -->
                        <Border
                            x:Name="rangeDisplayBorder"
                            Padding="4,2"
                            Background="#a0000000"
                            CornerRadius="2"
                            Visibility="Collapsed">
                            <TextBlock
                                x:Name="rangeDisplayTextBlock"
                                FontSize="12"
                                Foreground="White" />
                        </Border>
                    </Canvas>
                </Grid>
            </ScrollViewer>
        </Grid>

    </Grid>

</UserControl>
