<UserControl
    x:Class="ImageCropper.Views.UserControls.NumberBox"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ImageCropper.Views.UserControls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    VerticalAlignment="Center"
    d:DesignWidth="200"
    BorderThickness="1"
    mc:Ignorable="d">
    <Border x:Name="OverlayBorder" BorderThickness="1">
        <TextBox
            x:Name="MainTextBox"
            Margin="1"
            VerticalAlignment="Center"
            PreviewTextInput="MainTextBox_PreviewTextInput"
            Text="0"
            TextChanged="MainTextBox_TextChanged" />
    </Border>
</UserControl>
