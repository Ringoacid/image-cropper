<Window x:Class="ImageCropper.Views.Windows.DebugWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ImageCropper.Views.Windows"
        xmlns:usr="clr-namespace:ImageCropper.Views.UserControls"
        d:DataContext="{d:DesignInstance Type=local:DebugWindow}"
        mc:Ignorable="d"
        Title="DebugWindow" Height="450" Width="800">
    <Grid>
        <StackPanel HorizontalAlignment="Center">
            <StackPanel Orientation="Horizontal">
                <TextBlock VerticalAlignment="Center" Text="IsIntegerOnly:"/>
                <usr:ToggleSwitch IsChecked="{Binding ViewModel.IsIntegerOnly}"/>
            </StackPanel>
            <Button Content="乱数を設定" Command="{Binding ViewModel.SetRandomValueCommand}"/>
            <usr:NumberBox Value="{Binding ViewModel.Value}" IsIntegerOnly="{Binding ViewModel.IsIntegerOnly}" IsWarning="{Binding ViewModel.IsWarning}"/>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Value:"/>
                <TextBlock Text="{Binding ViewModel.Value}"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
